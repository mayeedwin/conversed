{
  "name": "@conversed/react",
  "version": "0.0.1-rc.3",
  "description": "React 18+ components and hooks for conversed rich AI chat UI",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@conversed/core": "0.0.1-rc.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.9.0"
  },
  "keywords": [
    "react",
    "ai",
    "chat",
    "conversed",
    "components"
  ],
  "license": "MIT"
}
